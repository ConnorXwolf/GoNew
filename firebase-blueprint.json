{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress tracking",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile picture URL" },
        "solvedProblems": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of IDs of problems solved by the user"
        },
        "stats": {
          "type": "object",
          "properties": {
            "totalPlayed": { "type": "integer", "description": "Total number of games played" },
            "totalCorrect": { "type": "integer", "description": "Total number of correct answers" },
            "maxStreak": { "type": "integer", "description": "Highest streak achieved" },
            "lastSolvedDate": { "type": "string", "format": "date-time", "description": "Last time the user solved a problem" }
          }
        },
        "achievements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of achievement IDs unlocked by the user"
        }
      },
      "required": ["uid", "email", "solvedProblems", "stats", "achievements"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and progress"
    }
  }
}
