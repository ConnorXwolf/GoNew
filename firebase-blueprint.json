{
  "entities": {
    "UserStats": {
      "title": "UserStats",
      "description": "User's learning progress statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "stats": {
          "type": "object",
          "description": "Mapping of difficulty levels to stats",
          "properties": {
            "初學": { "$ref": "LevelStat" },
            "基礎": { "$ref": "LevelStat" },
            "中階": { "$ref": "LevelStat" },
            "高階": { "$ref": "LevelStat" },
            "極限": { "$ref": "LevelStat" },
            "我的棋譜": { "$ref": "LevelStat" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last sync time" }
      },
      "required": ["uid", "stats"]
    },
    "UserSgf": {
      "title": "UserSgf",
      "description": "A saved SGF file for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "sgf": { "type": "string" },
        "createdAt": { "type": "integer" },
        "moveCount": { "type": "integer" },
        "folderId": { "type": "string", "description": "ID of the folder this SGF belongs to" }
      },
      "required": ["id", "title", "sgf", "createdAt"]
    },
    "UserFolder": {
      "title": "UserFolder",
      "description": "A folder created by the user to categorize SGFs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "LevelStat": {
      "title": "LevelStat",
      "type": "object",
      "properties": {
        "attempted": { "type": "integer" },
        "correct": { "type": "integer" }
      },
      "required": ["attempted", "correct"]
    },
    "SRSData": {
      "title": "SRSData",
      "description": "Spaced Repetition System data for a specific problem",
      "type": "object",
      "properties": {
        "problemId": { "type": "string" },
        "repetitions": { "type": "integer" },
        "interval": { "type": "integer" },
        "easeFactor": { "type": "number" },
        "nextReviewDate": { "type": "integer", "description": "Timestamp in milliseconds" },
        "lastReviewDate": { "type": "integer", "description": "Timestamp in milliseconds" }
      },
      "required": ["problemId", "repetitions", "interval", "easeFactor", "nextReviewDate", "lastReviewDate"]
    }
  },
  "firestore": {
    "/userStats/{userId}": {
      "schema": "UserStats",
      "description": "User learning progress"
    },
    "/userSRS/{userId}/problems/{problemId}": {
      "schema": "SRSData",
      "description": "User SRS data for a problem"
    },
    "/userSgfs/{userId}/sgfs/{sgfId}": {
      "schema": "UserSgf",
      "description": "User's saved SGF files"
    },
    "/userFolders/{userId}/folders/{folderId}": {
      "schema": "UserFolder",
      "description": "User's custom folders for SGFs"
    }
  }
}
