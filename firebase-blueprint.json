{
  "entities": {
    "UserStats": {
      "title": "UserStats",
      "description": "User's learning progress statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "stats": {
          "type": "object",
          "description": "Mapping of difficulty levels to stats",
          "properties": {
            "初學": { "$ref": "LevelStat" },
            "基礎": { "$ref": "LevelStat" },
            "中階": { "$ref": "LevelStat" },
            "高階": { "$ref": "LevelStat" },
            "極限": { "$ref": "LevelStat" }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last sync time" }
      },
      "required": ["uid", "stats"]
    },
    "LevelStat": {
      "title": "LevelStat",
      "type": "object",
      "properties": {
        "attempted": { "type": "integer" },
        "correct": { "type": "integer" }
      },
      "required": ["attempted", "correct"]
    }
  },
  "firestore": {
    "/userStats/{userId}": {
      "schema": "UserStats",
      "description": "User learning progress"
    }
  }
}
