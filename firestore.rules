rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userStats
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - email: string (optional) - The user's email address
    //   - displayName: string (optional) - User's name
    //   - stats: map (required) - Level-based stats
    //   - lastUpdated: timestamp (optional) - Last sync time
    //
    // ===============================================================

    // Collection: userSgfs
    // Document ID: sgfId (Unique ID)
    // Fields:
    //   - id: string (required) - Unique ID
    //   - title: string (required) - SGF title
    //   - sgf: string (required) - SGF content
    //   - createdAt: int (required) - Timestamp
    //   - moveCount: int (optional) - Number of moves
    //   - folderId: string (optional) - Folder ID
    //
    // ===============================================================

    // Collection: userFolders
    // Document ID: folderId (Unique ID)
    // Fields:
    //   - id: string (required) - Unique ID
    //   - name: string (required) - Folder name
    //   - createdAt: int (required) - Timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "c605277@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidLevelStat(stat) {
      return stat is map &&
             stat.keys().hasAll(['attempted', 'correct']) &&
             stat.attempted is int &&
             stat.correct is int &&
             stat.attempted >= 0 &&
             stat.correct >= 0;
    }

    function isValidUserStats(data) {
      return data.keys().hasAll(['uid', 'stats']) &&
             data.uid is string &&
             data.stats is map &&
             (!('email' in data) || data.email is string) &&
             (!('displayName' in data) || data.displayName is string);
    }

    function isValidSRSData(data) {
      return data.keys().hasAll(['problemId', 'repetitions', 'interval', 'easeFactor', 'nextReviewDate', 'lastReviewDate']) &&
             data.problemId is string &&
             data.repetitions is int &&
             data.interval is int &&
             data.easeFactor is number &&
             data.nextReviewDate is int &&
             data.lastReviewDate is int;
    }

    function isValidUserSgf(data) {
      return data.keys().hasAll(['id', 'title', 'sgf', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.sgf is string && data.sgf.size() > 0 && data.sgf.size() < 1000000 &&
             data.createdAt is int &&
             (!('moveCount' in data) || data.moveCount is int) &&
             (!('folderId' in data) || data.folderId is string);
    }

    function isValidUserFolder(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50 &&
             data.createdAt is int;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userStats/{userId} {
      // Only the owner can read/write their own stats
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidUserStats(request.resource.data);
      
      // Allow update if owner and data is valid
      allow update: if isOwner(userId) && isValidUserStats(request.resource.data);
    }

    match /userSRS/{userId}/problems/{problemId} {
      // Only the owner can read/write their own SRS data
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidSRSData(request.resource.data);
      
      // Allow update if owner and data is valid
      allow update: if isOwner(userId) && isValidSRSData(request.resource.data);
    }

    match /userSgfs/{userId}/sgfs/{sgfId} {
      // Only the owner can read/write their own SGFs
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidUserSgf(request.resource.data);
      
      // Allow update if owner and data is valid
      allow update: if isOwner(userId) && isValidUserSgf(request.resource.data);

      // Allow deletion if owner
      allow delete: if isOwner(userId);
    }

    match /userFolders/{userId}/folders/{folderId} {
      // Only the owner can read/write their own folders
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidUserFolder(request.resource.data);
      
      // Allow update if owner and data is valid
      allow update: if isOwner(userId) && isValidUserFolder(request.resource.data);

      // Allow deletion if owner
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
