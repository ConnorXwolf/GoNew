rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - email: string (required) - The user's email address
    //   - displayName: string (optional) - User's name
    //   - photoURL: string (optional) - User's avatar
    //   - solvedProblems: list (required) - Array of problem IDs
    //   - stats: map (required) - User stats (totalPlayed, totalCorrect, maxStreak, lastSolvedDate)
    //   - achievements: list (required) - Array of achievement IDs
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'solvedProblems', 'stats', 'achievements']) &&
             data.uid is string &&
             data.email is string &&
             data.solvedProblems is list &&
             data.stats is map &&
             data.stats.keys().hasAll(['totalPlayed', 'totalCorrect', 'maxStreak', 'lastSolvedDate']) &&
             data.stats.totalPlayed is int &&
             data.stats.totalCorrect is int &&
             data.stats.maxStreak is int &&
             data.stats.lastSolvedDate is string &&
             data.achievements is list;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "c605277@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Only the owner can read their own profile (PII protection)
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow creation if authenticated and data is valid
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Allow update if owner and data is valid, preventing role escalation
      allow update: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
    }

    match /nicknames/{nickname} {
      // Anyone can check if a nickname exists
      allow read: if true;
      // Only the owner can create their nickname mapping
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
